-- Credit: FrCynda
if syntaxcheck then return end
[ENABLE]
local function autoAttach()
   local processNames = { "nightreign.exe", "start_protected_game.exe" }
   local maxAttempts = 10

   for _ = 1, maxAttempts do
      for _, processName in ipairs(processNames) do
         local pid = getProcessIDFromProcessName(processName)
         if pid and openProcess(pid) then
            if processName == "nightreign.exe" or getAddressSafe("nightreign.exe") then
               return true, processName
            end
         end
      end
      sleep(500)
   end

   return false, "Unable to find or attach to nightreign.exe"
end

