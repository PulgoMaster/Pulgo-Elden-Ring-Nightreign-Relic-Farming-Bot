local function registerBaseAddr(processName, baseName, byteArray, offset, len, ripOffset, optional)
  assert(type(baseName) == "string" and (offset == nil or type(offset) == "number"), "registerBaseByKey: bad argument type")
  local address = AOBScanModuleUnique(processName, byteArray, "+X")
    if not address then
       if not optional then
          printf("Failed to find AoB for: %s",baseName)
       end
       return
    end
  if not len then len = 7 end
  if not ripOffset then ripOffset = 3 end
    if offset then
       address = address + offset
    end
  local _Symbol = address + len + readInteger(address+ripOffset,true)
  registerSymbol(baseName,_Symbol)
end

